  "goals": [
    {
      "id": "62f977e7ff0c",
      "name": "Play classic games on modern computers",
      "summary": "Help a user identify an old game from memory, find a legal acquisition path, adapt it for their current machine, install or configure it with approval, create a launcher, and verify the game starts. Community branches under this Goal should be forkable recipes for lawful game restoration and compatibility, not piracy or DRM bypass.",
      "tags": [
        "classic-games",
        "game-preservation",
        "compatibility",
        "local-app",
        "installers",
        "legal-provenance"
      ],
      "author": "anonymous",
      "visibility": "public"
    },
    {
      "id": "dd187997039b",
      "name": "Connect public web sources to Workflow universes",
      "summary": "Let a chatbot fetch a public source URL, store the snapshot in a Workflow universe through MCP, preserve attribution/provenance, and route proposed changes through branch/gate review before promotion. Echoes of the Cosmos Reddit/RSS is the first live example.",
      "tags": [
        "public-source",
        "mcp",
        "universe",
        "echoes",
        "reddit",
        "community",
        "canon-gate"
      ],
      "author": "anonymous",
      "visibility": "public"
    },
    {
      "id": "4ff5862cc26d",
      "name": "Route a patch request through investigation, PR, release, and live observation",
      "summary": "Community-driven live-state loop for Workflow changes. Any patch request starts as a wiki report, runs through the best known investigation branch, passes gate review, dispatches a coding-team branch to produce a PR, passes further gates, and is then observed after landing with real or simulated users. The goal is long-horizon self-improvement: gates can send work backward with edits whenever evidence shows the patch did not land or did not work as intended.",
      "tags": [
        "patch-loop",
        "community",
        "gatekeeping",
        "pr",
        "live-observation",
        "self-improvement"
      ],
      "author": "anonymous",
      "visibility": "public"
    },
    {
      "id": "f10caea2e437",
      "name": "Turn a Workflow bug into a patch packet",
      "summary": "Given a filed Workflow bug report, produce an actionable patch packet: normalized bug summary, minimal repro, likely root cause map, implementation sketch, regression tests, and attachable maintainer comment. Intended to be run automatically after wiki action=file_bug via the canonical branch for this goal.",
      "tags": [
        "bugs",
        "patch-packet",
        "workflow-engine",
        "daemon",
        "automation"
      ],
      "author": "anonymous",
      "visibility": "public"
    },
    {
      "id": "454b6e72348b",
      "name": "Complete a software project end-to-end",
      "summary": "Take a project brief and acceptance criteria as input; coordinate a team of Claude Code agents (lead, dev, checker, plus optional specialized roles) to plan, implement, test, and iterate until acceptance criteria are met. Human review is optional throughout — the system can run autonomously with retry budgets and task decomposition as escalation mechanisms. Branches bound to this goal range from 3-node minimum (lead/dev/checker) to 20-node production (with security/perf/ops/docs specialization).",
      "tags": [
        "agent-teams",
        "claude-code",
        "autonomous",
        "end-to-end"
      ],
      "author": "anonymous",
      "visibility": "public"
    },
    {
