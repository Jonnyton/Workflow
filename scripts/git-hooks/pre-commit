#!/usr/bin/env bash
# Workflow pre-commit invariants.
#
# Enforces four invariants at commit time so no session has to
# re-check them by hand:
#
#   1. Skill-mirror parity. If any file in `.agents/skills/` is
#      staged, the Claude Code mirror at `.claude/skills/` is
#      refreshed by running scripts/sync-skills.ps1.
#
#   2. Plugin-mirror parity. For every staged canonical file at
#      `workflow/**`, the packaged-plugin copy at
#      `packaging/claude-plugin/plugins/workflow-universe-server/runtime/workflow/**`
#      must be byte-identical. Commits that break parity fail.
#
#   3. Mojibake detection. Staged `.md` / `.py` / `.json` / `.toml` /
#      `.txt` files are scanned for CP-1252-as-UTF-8 garbled sequences
#      (â€" in place of — and similar). Any match fails the commit
#      with a file:line report + autofix hint.
#
#   4. Import-graph smoke. When any `workflow/**/*.py` is staged, run
#      scripts/import_graph_smoke.py to catch missing-symbol regressions
#      of the 2026-04-19 P0 class (R7a-style refactor declaring names
#      that don't resolve at runtime). Only runs on workflow/ touches
#      so non-python commits don't pay the import cost.
#
# Override with `git commit --no-verify` for exceptional cases
# (e.g. intentional mirror-only edit during a sync commit).
#
# Installed via `powershell -ExecutionPolicy Bypass -File scripts/install-git-hooks.ps1`.
# Source of truth lives at `scripts/git-hooks/pre-commit`.

set -u

REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null)"
if [ -z "${REPO_ROOT}" ]; then
  echo "pre-commit: not inside a git repo; skipping invariants" >&2
  exit 0
fi

cd "${REPO_ROOT}" || exit 0

RED=$'\033[31m'
GREEN=$'\033[32m'
YELLOW=$'\033[33m'
RESET=$'\033[0m'

# --- 1. Skill-mirror parity ------------------------------------------

SKILL_SOURCE_CHANGED=0
if git diff --cached --name-only | grep -q '^\.agents/skills/'; then
  SKILL_SOURCE_CHANGED=1
fi

if [ "${SKILL_SOURCE_CHANGED}" -eq 1 ]; then
  echo "${YELLOW}pre-commit: .agents/skills/ staged — resyncing .claude/skills/${RESET}"
  if command -v powershell.exe >/dev/null 2>&1; then
    powershell.exe -ExecutionPolicy Bypass -File scripts/sync-skills.ps1 >/dev/null 2>&1
    sync_status=$?
  elif command -v pwsh >/dev/null 2>&1; then
    pwsh -ExecutionPolicy Bypass -File scripts/sync-skills.ps1 >/dev/null 2>&1
    sync_status=$?
  else
    echo "${RED}pre-commit: powershell not available to run sync-skills.ps1; skipping auto-resync${RESET}" >&2
    sync_status=0
  fi
  if [ "${sync_status}" -ne 0 ]; then
    echo "${RED}pre-commit: sync-skills.ps1 failed (exit ${sync_status})${RESET}" >&2
    exit 1
  fi
  # Stage any refreshed .claude/skills/* so the commit reflects them.
  git add .claude/skills 2>/dev/null || true
fi

# --- 2. Plugin-mirror parity -----------------------------------------

MIRROR_PREFIX="packaging/claude-plugin/plugins/workflow-universe-server/runtime"

# List staged canonical paths under workflow/ (excluding subpackaged-only
# paths that don't have a mirror — currently none, but defensive against
# future additions).
STAGED_CANONICAL=$(
  git diff --cached --name-only --diff-filter=ACMR \
    | grep -E '^workflow/.*\.(py|md|json|toml)$' || true
)

if [ -z "${STAGED_CANONICAL}" ]; then
  echo "${GREEN}pre-commit: no canonical workflow/ changes — mirror parity N/A${RESET}"
else
  MIRROR_MISMATCHES=()
  for canon in ${STAGED_CANONICAL}; do
    mirror="${MIRROR_PREFIX}/${canon}"
    if [ ! -f "${mirror}" ]; then
      # Canonical file has no mirror counterpart — acceptable, skip.
      # (E.g. new workflow/ modules before the plugin build picks them up.)
      continue
    fi
    if ! cmp -s "${canon}" "${mirror}"; then
      MIRROR_MISMATCHES+=("${canon}")
    fi
  done

  if [ "${#MIRROR_MISMATCHES[@]}" -gt 0 ]; then
    echo "${RED}pre-commit: plugin-mirror parity broken.${RESET}" >&2
    echo "" >&2
    echo "The following staged canonical files diverge from their plugin-mirror copies:" >&2
    for f in "${MIRROR_MISMATCHES[@]}"; do
      echo "  ${f}" >&2
      echo "    mirror: ${MIRROR_PREFIX}/${f}" >&2
    done
    echo "" >&2
    echo "Resync options:" >&2
    echo "  1. Re-run the plugin build:" >&2
    echo "       python packaging/claude-plugin/build_plugin.py" >&2
    echo "  2. Or copy each canonical file to its mirror path and" >&2
    echo "     stage both in the same commit." >&2
    echo "" >&2
    echo "Override with --no-verify if this is an intentional one-sided edit." >&2
    exit 1
  fi

  CHECKED_COUNT=$(printf '%s\n' "${STAGED_CANONICAL}" | wc -l | tr -d ' ')
  echo "${GREEN}pre-commit: mirror parity verified (${CHECKED_COUNT} canonical files checked)${RESET}"
fi

# --- 3. Mojibake detection ------------------------------------------

STAGED_TEXT=$(
  git diff --cached --name-only --diff-filter=ACMR \
    | grep -E '\.(md|py|json|toml|txt)$' \
    | grep -v -E '^scripts/fix-mojibake\.py$|^tests/test_fix_mojibake\.py$' \
    || true
)

if [ -n "${STAGED_TEXT}" ]; then
  # Only scan files that still exist on disk (deleted files slip past
  # the diff-filter on rename cases). Pass the full set to fix-mojibake.py
  # in detection mode; exit 1 on any match.
  EXISTING_PATHS=()
  while IFS= read -r p; do
    if [ -f "${p}" ]; then
      EXISTING_PATHS+=("${p}")
    fi
  done <<< "${STAGED_TEXT}"

  if [ "${#EXISTING_PATHS[@]}" -gt 0 ]; then
    # Find a usable python. Prefer `python` on PATH; fall back to py -3
    # via the Windows launcher.
    if command -v python >/dev/null 2>&1; then
      PYTHON_BIN="python"
    elif command -v python3 >/dev/null 2>&1; then
      PYTHON_BIN="python3"
    elif command -v py >/dev/null 2>&1; then
      PYTHON_BIN="py -3"
    else
      echo "${YELLOW}pre-commit: python not available; skipping mojibake scan${RESET}" >&2
      PYTHON_BIN=""
    fi

    if [ -n "${PYTHON_BIN}" ]; then
      if [ ! -f scripts/fix-mojibake.py ]; then
        echo "${YELLOW}pre-commit: scripts/fix-mojibake.py missing; skipping mojibake scan${RESET}" >&2
      elif ! ${PYTHON_BIN} scripts/fix-mojibake.py "${EXISTING_PATHS[@]}"; then
        echo "" >&2
        echo "${RED}pre-commit: mojibake detected in staged files.${RESET}" >&2
        echo "Run this to repair in-place, then re-stage:" >&2
        echo "  ${PYTHON_BIN} scripts/fix-mojibake.py --autofix <paths>" >&2
        echo "Override with --no-verify if intentional." >&2
        exit 1
      else
        echo "${GREEN}pre-commit: mojibake scan clean (${#EXISTING_PATHS[@]} text file(s) checked)${RESET}"
      fi
    fi
  fi
fi

# --- 4. Import-graph smoke ------------------------------------------

STAGED_WORKFLOW_PY=$(
  git diff --cached --name-only --diff-filter=ACMRD \
    | grep -E '^(workflow|packaging/claude-plugin/plugins/workflow-universe-server/runtime/workflow)/.*\.py$' \
    || true
)

if [ -n "${STAGED_WORKFLOW_PY}" ]; then
  if command -v python >/dev/null 2>&1; then
    PYTHON_BIN="python"
  elif command -v python3 >/dev/null 2>&1; then
    PYTHON_BIN="python3"
  elif command -v py >/dev/null 2>&1; then
    PYTHON_BIN="py -3"
  else
    echo "${YELLOW}pre-commit: python not available; skipping import-graph smoke${RESET}" >&2
    PYTHON_BIN=""
  fi

  if [ -n "${PYTHON_BIN}" ] && [ -f scripts/import_graph_smoke.py ]; then
    if ! ${PYTHON_BIN} scripts/import_graph_smoke.py --primary-only; then
      echo "" >&2
      echo "${RED}pre-commit: import-graph regression detected.${RESET}" >&2
      echo "A staged workflow/ change breaks at-import-time symbol" >&2
      echo "resolution — this is the 2026-04-19 P0 class of bug." >&2
      echo "" >&2
      echo "Fix: check __all__ lists in the staged module(s) and make" >&2
      echo "sure every declared name actually resolves. Re-run:" >&2
      echo "  ${PYTHON_BIN} scripts/import_graph_smoke.py --verbose" >&2
      echo "" >&2
      echo "Override with --no-verify if intentional." >&2
      exit 1
    fi
    echo "${GREEN}pre-commit: import-graph smoke clean (primary targets)${RESET}"
  fi
fi

exit 0
