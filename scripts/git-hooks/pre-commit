#!/usr/bin/env bash
# Workflow pre-commit invariants.
#
# Enforces five invariants at commit time so no session has to
# re-check them by hand:
#
#   1. Skill-mirror parity. If any file in `.agents/skills/` is
#      staged, the Claude Code mirror at `.claude/skills/` is
#      refreshed by running scripts/sync-skills.ps1.
#
#   2. Plugin-mirror parity. For every staged canonical file at
#      `workflow/**`, the packaged-plugin copy at
#      `packaging/claude-plugin/plugins/workflow-universe-server/runtime/workflow/**`
#      must be byte-identical. Commits that break parity fail.
#
#   3. Mojibake detection. Staged `.md` / `.py` / `.json` / `.toml` /
#      `.txt` files are scanned for CP-1252-as-UTF-8 garbled sequences
#      (â€" in place of — and similar). Any match fails the commit
#      with a file:line report + autofix hint.
#
#   4. Import-graph smoke. When any `workflow/**/*.py` is staged, run
#      scripts/import_graph_smoke.py to catch missing-symbol regressions
#      of the 2026-04-19 P0 class (R7a-style refactor declaring names
#      that don't resolve at runtime). Only runs on workflow/ touches
#      so non-python commits don't pay the import cost.
#
#   5. Worker CF Access header invariant. When `deploy/cloudflare-worker/worker.js`
#      is staged, verify it still contains both `env.CF_ACCESS_CLIENT_ID` and
#      `env.CF_ACCESS_CLIENT_SECRET` reads. Prevents accidentally removing
#      the Access header injection (root cause of the 2026-04-20 incident where
#      the Worker was committed without the Access headers deployed).
#
# Override with `git commit --no-verify` for exceptional cases
# (e.g. intentional mirror-only edit during a sync commit).
#
# Installed via `powershell -ExecutionPolicy Bypass -File scripts/install-git-hooks.ps1`.
# Source of truth lives at `scripts/git-hooks/pre-commit`.

set -u

REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null)"
if [ -z "${REPO_ROOT}" ]; then
  echo "pre-commit: not inside a git repo; skipping invariants" >&2
  exit 0
fi

cd "${REPO_ROOT}" || exit 0

RED=$'\033[31m'
GREEN=$'\033[32m'
YELLOW=$'\033[33m'
RESET=$'\033[0m'

# --- 1. Skill-mirror parity ------------------------------------------

SKILL_SOURCE_CHANGED=0
if git diff --cached --name-only | grep -q '^\.agents/skills/'; then
  SKILL_SOURCE_CHANGED=1
fi

if [ "${SKILL_SOURCE_CHANGED}" -eq 1 ]; then
  echo "${YELLOW}pre-commit: .agents/skills/ staged — resyncing .claude/skills/${RESET}"
  if command -v powershell.exe >/dev/null 2>&1; then
    powershell.exe -ExecutionPolicy Bypass -File scripts/sync-skills.ps1 >/dev/null 2>&1
    sync_status=$?
  elif command -v pwsh >/dev/null 2>&1; then
    pwsh -ExecutionPolicy Bypass -File scripts/sync-skills.ps1 >/dev/null 2>&1
    sync_status=$?
  else
    echo "${RED}pre-commit: powershell not available to run sync-skills.ps1; skipping auto-resync${RESET}" >&2
    sync_status=0
  fi
  if [ "${sync_status}" -ne 0 ]; then
    echo "${RED}pre-commit: sync-skills.ps1 failed (exit ${sync_status})${RESET}" >&2
    exit 1
  fi
  # Stage any refreshed .claude/skills/* so the commit reflects them.
  git add .claude/skills 2>/dev/null || true
fi

# --- 2. Plugin-mirror parity -----------------------------------------

MIRROR_PREFIX="packaging/claude-plugin/plugins/workflow-universe-server/runtime"

# List staged canonical paths under workflow/ (excluding subpackaged-only
# paths that don't have a mirror — currently none, but defensive against
# future additions).
STAGED_CANONICAL=$(
  git diff --cached --name-only --diff-filter=ACMR \
    | grep -E '^workflow/.*\.(py|md|json|toml)$' || true
)

if [ -z "${STAGED_CANONICAL}" ]; then
  echo "${GREEN}pre-commit: no canonical workflow/ changes — mirror parity N/A${RESET}"
else
  MIRROR_MISMATCHES=()
  for canon in ${STAGED_CANONICAL}; do
    mirror="${MIRROR_PREFIX}/${canon}"
    if [ ! -f "${mirror}" ]; then
      # Canonical file has no mirror counterpart — acceptable, skip.
      # (E.g. new workflow/ modules before the plugin build picks them up.)
      continue
    fi
    if ! cmp -s "${canon}" "${mirror}"; then
      MIRROR_MISMATCHES+=("${canon}")
    fi
  done

  if [ "${#MIRROR_MISMATCHES[@]}" -gt 0 ]; then
    echo "${RED}pre-commit: plugin-mirror parity broken.${RESET}" >&2
    echo "" >&2
    echo "The following staged canonical files diverge from their plugin-mirror copies:" >&2
    for f in "${MIRROR_MISMATCHES[@]}"; do
      echo "  ${f}" >&2
      echo "    mirror: ${MIRROR_PREFIX}/${f}" >&2
    done
    echo "" >&2
    echo "Resync options:" >&2
    echo "  1. Re-run the plugin build:" >&2
    echo "       python packaging/claude-plugin/build_plugin.py" >&2
    echo "  2. Or copy each canonical file to its mirror path and" >&2
    echo "     stage both in the same commit." >&2
    echo "" >&2
    echo "Override with --no-verify if this is an intentional one-sided edit." >&2
    exit 1
  fi

  CHECKED_COUNT=$(printf '%s\n' "${STAGED_CANONICAL}" | wc -l | tr -d ' ')
  echo "${GREEN}pre-commit: mirror parity verified (${CHECKED_COUNT} canonical files checked)${RESET}"
fi

# --- 3. Mojibake detection ------------------------------------------

STAGED_TEXT=$(
  git diff --cached --name-only --diff-filter=ACMR \
    | grep -E '\.(md|py|json|toml|txt)$' \
    | grep -v -E '^scripts/fix-mojibake\.py$|^tests/test_fix_mojibake\.py$' \
    || true
)

if [ -n "${STAGED_TEXT}" ]; then
  # Only scan files that still exist on disk (deleted files slip past
  # the diff-filter on rename cases). Pass the full set to fix-mojibake.py
  # in detection mode; exit 1 on any match.
  EXISTING_PATHS=()
  while IFS= read -r p; do
    if [ -f "${p}" ]; then
      EXISTING_PATHS+=("${p}")
    fi
  done <<< "${STAGED_TEXT}"

  if [ "${#EXISTING_PATHS[@]}" -gt 0 ]; then
    # Find a usable python. Prefer `python` on PATH; fall back to py -3
    # via the Windows launcher.
    if command -v python >/dev/null 2>&1; then
      PYTHON_BIN="python"
    elif command -v python3 >/dev/null 2>&1; then
      PYTHON_BIN="python3"
    elif command -v py >/dev/null 2>&1; then
      PYTHON_BIN="py -3"
    else
      echo "${YELLOW}pre-commit: python not available; skipping mojibake scan${RESET}" >&2
      PYTHON_BIN=""
    fi

    if [ -n "${PYTHON_BIN}" ]; then
      if [ ! -f scripts/fix-mojibake.py ]; then
        echo "${YELLOW}pre-commit: scripts/fix-mojibake.py missing; skipping mojibake scan${RESET}" >&2
      elif ! ${PYTHON_BIN} scripts/fix-mojibake.py "${EXISTING_PATHS[@]}"; then
        echo "" >&2
        echo "${RED}pre-commit: mojibake detected in staged files.${RESET}" >&2
        echo "Run this to repair in-place, then re-stage:" >&2
        echo "  ${PYTHON_BIN} scripts/fix-mojibake.py --autofix <paths>" >&2
        echo "Override with --no-verify if intentional." >&2
        exit 1
      else
        echo "${GREEN}pre-commit: mojibake scan clean (${#EXISTING_PATHS[@]} text file(s) checked)${RESET}"
      fi
    fi
  fi
fi

# --- 4. Import-graph smoke ------------------------------------------

STAGED_WORKFLOW_PY=$(
  git diff --cached --name-only --diff-filter=ACMRD \
    | grep -E '^(workflow|packaging/claude-plugin/plugins/workflow-universe-server/runtime/workflow)/.*\.py$' \
    || true
)

if [ -n "${STAGED_WORKFLOW_PY}" ]; then
  if command -v python >/dev/null 2>&1; then
    PYTHON_BIN="python"
  elif command -v python3 >/dev/null 2>&1; then
    PYTHON_BIN="python3"
  elif command -v py >/dev/null 2>&1; then
    PYTHON_BIN="py -3"
  else
    echo "${YELLOW}pre-commit: python not available; skipping import-graph smoke${RESET}" >&2
    PYTHON_BIN=""
  fi

  if [ -n "${PYTHON_BIN}" ] && [ -f scripts/import_graph_smoke.py ]; then
    if ! ${PYTHON_BIN} scripts/import_graph_smoke.py --primary-only; then
      echo "" >&2
      echo "${RED}pre-commit: import-graph regression detected.${RESET}" >&2
      echo "A staged workflow/ change breaks at-import-time symbol" >&2
      echo "resolution — this is the 2026-04-19 P0 class of bug." >&2
      echo "" >&2
      echo "Fix: check __all__ lists in the staged module(s) and make" >&2
      echo "sure every declared name actually resolves. Re-run:" >&2
      echo "  ${PYTHON_BIN} scripts/import_graph_smoke.py --verbose" >&2
      echo "" >&2
      echo "Override with --no-verify if intentional." >&2
      exit 1
    fi
    echo "${GREEN}pre-commit: import-graph smoke clean (primary targets)${RESET}"
  fi
fi

# --- 5. data_dir bypass lint -----------------------------------------
#
# Row B established ``workflow.storage.data_dir()`` as the canonical
# resolver for on-disk state paths. Two sites pre-existing-Row-B
# bypassed it by reading UNIVERSE_SERVER_BASE directly + defaulting to
# CWD-relative ``output``, which wrote to /app/output in containers
# (ephemeral, lost on restart). Fixed in commit ${ROW_B_CLEANUP}.
#
# Prevent the regression: any staged python file under workflow/ that
# reads UNIVERSE_SERVER_BASE via os.environ.get is suspect — it should
# route through data_dir() instead. Grep the staged diff; fail on hit.
#
# Exempt: ``workflow/storage/__init__.py`` itself defines the resolver
# and is allowed to read the legacy env var for backcompat.

STAGED_WF_PY=$(
  git diff --cached --name-only --diff-filter=ACMRD \
    | grep -E '^(workflow|packaging/claude-plugin/plugins/workflow-universe-server/runtime/workflow)/.*\.py$' \
    | grep -v -E '(workflow|runtime/workflow)/storage/__init__\.py$' \
    || true
)

if [ -n "${STAGED_WF_PY}" ]; then
  BYPASS_HITS=()
  # Pattern matches both UNIVERSE_SERVER_BASE (data_dir bypass, Row B)
  # AND WIKI_PATH / WORKFLOW_WIKI_PATH (wiki_path bypass, Row B-pattern
  # cleanup 2026-04-20). Anything that should route through the
  # resolvers in workflow/storage/__init__.py.
  BYPASS_RE='os\.environ\.get\s*\(\s*["'"'"'](UNIVERSE_SERVER_BASE|WIKI_PATH|WORKFLOW_WIKI_PATH)'
  while IFS= read -r f; do
    [ -z "${f}" ] && continue
    [ -f "${f}" ] || continue
    while IFS=: read -r ln rest; do
      # Skip comment-only matches.
      case "$(echo "${rest}" | sed 's/^[[:space:]]*//')" in
        '#'*) continue;;
      esac
      BYPASS_HITS+=("${f}:${ln}:${rest}")
    done < <(grep -nE "${BYPASS_RE}" "${f}" 2>/dev/null || true)
  done <<< "${STAGED_WF_PY}"

  if [ "${#BYPASS_HITS[@]}" -gt 0 ]; then
    echo "${RED}pre-commit: path-resolver bypass detected.${RESET}" >&2
    echo "" >&2
    echo "The following staged lines read UNIVERSE_SERVER_BASE / WIKI_PATH /" >&2
    echo "WORKFLOW_WIKI_PATH directly instead of routing through the" >&2
    echo "canonical resolvers in workflow.storage:" >&2
    for h in "${BYPASS_HITS[@]}"; do
      echo "  ${h}" >&2
    done
    echo "" >&2
    echo "Fix (choose the right resolver):" >&2
    echo "  from workflow.storage import data_dir      # state / DBs / per-universe dirs" >&2
    echo "  from workflow.storage import wiki_path     # knowledge wiki root" >&2
    echo "" >&2
    echo "Why: Row B (data_dir) + Row B-pattern wiki cleanup established these" >&2
    echo "as the canonical resolvers. Direct env reads bypass them + default" >&2
    echo "to broken fallbacks (CWD-relative \"output\" for data_dir, hardcoded" >&2
    echo "Windows dev path for WIKI_PATH). Both break containerized deploys." >&2
    echo "" >&2
    echo "Exempt: workflow/storage/__init__.py (defines the resolvers)." >&2
    echo "Override with --no-verify if intentional." >&2
    exit 1
  fi
  echo "${GREEN}pre-commit: path-resolver bypass lint clean${RESET}"
fi

# --- 6. Worker CF Access header invariant ---------------------------
#
# When worker.js is staged, verify CF Access header reads are present.
# Delegates to scripts/pre_commit_invariant_worker.py so the logic
# is testable in Python without re-parsing shell.

if git diff --cached --name-only | grep -q '^deploy/cloudflare-worker/worker\.js$'; then
  if command -v python >/dev/null 2>&1; then
    PYTHON_BIN="python"
  elif command -v python3 >/dev/null 2>&1; then
    PYTHON_BIN="python3"
  elif command -v py >/dev/null 2>&1; then
    PYTHON_BIN="py -3"
  else
    echo "${YELLOW}pre-commit: python not available; skipping Worker CF Access header invariant${RESET}" >&2
    PYTHON_BIN=""
  fi

  if [ -n "${PYTHON_BIN}" ]; then
    if [ ! -f scripts/pre_commit_invariant_worker.py ]; then
      echo "${YELLOW}pre-commit: scripts/pre_commit_invariant_worker.py missing; skipping${RESET}" >&2
    elif ! ${PYTHON_BIN} scripts/pre_commit_invariant_worker.py; then
      echo "" >&2
      echo "${RED}pre-commit: Worker CF Access invariant failed.${RESET}" >&2
      echo "See message above. Override with --no-verify if removal is intentional." >&2
      exit 1
    fi
  fi
fi

# --- 7. actionlint on staged workflow files -------------------------
#
# Dev flagged "actionlint not available locally" 3 consecutive tasks
# before this invariant landed — workflow-file bugs were only caught by
# verifier/CI or by production breaking. Run actionlint against staged
# `.github/workflows/*.yml` changes. Delegates to
# scripts/pre_commit_invariant_actionlint.py so the logic is Python-
# testable. No-ops when actionlint binary is missing locally — CI
# (.github/workflows/actionlint.yml) is the authoritative gate.

if git diff --cached --name-only | grep -qE '^\.github/workflows/.+\.ya?ml$'; then
  if command -v python >/dev/null 2>&1; then
    PYTHON_BIN="python"
  elif command -v python3 >/dev/null 2>&1; then
    PYTHON_BIN="python3"
  elif command -v py >/dev/null 2>&1; then
    PYTHON_BIN="py -3"
  else
    echo "${YELLOW}pre-commit: python not available; skipping actionlint invariant${RESET}" >&2
    PYTHON_BIN=""
  fi

  if [ -n "${PYTHON_BIN}" ]; then
    if [ ! -f scripts/pre_commit_invariant_actionlint.py ]; then
      echo "${YELLOW}pre-commit: scripts/pre_commit_invariant_actionlint.py missing; skipping${RESET}" >&2
    elif ! ${PYTHON_BIN} scripts/pre_commit_invariant_actionlint.py; then
      echo "" >&2
      echo "${RED}pre-commit: actionlint invariant failed.${RESET}" >&2
      echo "See findings above. Override with --no-verify if intentional." >&2
      exit 1
    fi
  fi
fi

# --- 8. Wiki BUG approval gate ---
#
# Host directive 2026-04-22: wiki BUG-* pages are user-submitted and could
# contain malicious designs disguised as fixes. Before code that references
# a BUG-NNN ID can land, the navigator must have vetted that bug via
# scripts/navigator_approve_bug.py (which writes .claude/wiki-bug-approvals.json).
#
# This invariant scans staged content for BUG-NNN references and blocks
# the commit if any referenced ID is not in the approvals file.
#
# Override with --no-verify only for navigator's own approvals-file commits
# (if they ever become tracked) or for bugs you intentionally cite without
# implementing (e.g., docstrings explaining the existence of a known bug).

STAGED_TEXT_FILES=$(git diff --cached --name-only --diff-filter=ACMR | \
  grep -vE '^(\.claude/wiki-bug-approvals\.json|scripts/hooks/wiki_bug_gate\.py|scripts/navigator_(read|approve)_bug\.py|ideas/|docs/audits/|\.agents/activity\.log)' || true)

if [ -n "${STAGED_TEXT_FILES}" ]; then
  BUG_IDS=$(echo "${STAGED_TEXT_FILES}" | xargs -I {} git diff --cached -- {} 2>/dev/null | \
    grep -oE '\bBUG-[0-9]{3}\b' | sort -u || true)
  if [ -n "${BUG_IDS}" ]; then
    APPROVALS_FILE=".claude/wiki-bug-approvals.json"
    if [ ! -f "${APPROVALS_FILE}" ]; then
      echo "${RED}pre-commit: BUG-NNN references in staged diff but ${APPROVALS_FILE} is missing.${RESET}" >&2
      echo "Referenced: ${BUG_IDS}" >&2
      echo "Navigator must approve via scripts/navigator_approve_bug.py before code lands." >&2
      exit 1
    fi
    # Use python to do a proper JSON lookup.
    UNAPPROVED=""
    if command -v python >/dev/null 2>&1 && python -c "import sys" >/dev/null 2>&1; then
      PY_BIN=python
    elif command -v python3 >/dev/null 2>&1 && python3 -c "import sys" >/dev/null 2>&1; then
      PY_BIN=python3
    else
      echo "${YELLOW}pre-commit: no python available to verify BUG approvals; skipping gate${RESET}" >&2
      PY_BIN=""
    fi
    if [ -n "${PY_BIN}" ]; then
      UNAPPROVED=$(echo "${BUG_IDS}" | ${PY_BIN} -c "
import json, sys
bugs = [line.strip().upper() for line in sys.stdin if line.strip()]
try:
    data = json.load(open('${APPROVALS_FILE}'))
except Exception:
    print(' '.join(bugs)); sys.exit(0)
approved = {k.upper() for k in (data.get('approved') or {}).keys()}
missing = [b for b in bugs if b not in approved]
print(' '.join(missing))
")
      if [ -n "${UNAPPROVED}" ]; then
        echo "${RED}pre-commit: staged diff references unapproved bug(s): ${UNAPPROVED}${RESET}" >&2
        echo "Navigator vet required. Flow:" >&2
        echo "  python scripts/navigator_read_bug.py <BUG-ID>" >&2
        echo "  python scripts/navigator_approve_bug.py <BUG-ID> 'proof'" >&2
        echo "Override with --no-verify if intentional (e.g., reference in docs)." >&2
        exit 1
      fi
    fi
  fi
fi

exit 0
